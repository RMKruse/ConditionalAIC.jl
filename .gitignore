# ──────────────────────────────────────────────────────────────
# OS / editor cruft
# ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
*~
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# ──────────────────────────────────────────────────────────────
# Julia
# ──────────────────────────────────────────────────────────────
# Compiled / precompiled artifacts
*.jl.cov
*.jl.*.cov
*.jl.mem
deps/deps.jl
deps/build.log
deps/downloads/
deps/usr/
deps/src/

# Package operation logs
*.jl.history

# Documentation build output (Documenter.jl)
docs/build/
docs/site/

# Manifest files — none are committed (top-level or sub-environment).
# The exact `MixedModels = "=X.Y.Z"` compat pin in Project.toml is the
# reproducibility guarantee; a committed Manifest cannot serve the
# 1.10/1.11/nightly CI matrix, since stdlib JLLs are bundled differently per
# Julia version. See docs/adr/0004-no-committed-manifest.md.
**/Manifest.toml

# ──────────────────────────────────────────────────────────────
# R
# ──────────────────────────────────────────────────────────────
# History and session data
.Rhistory
.Rapp.history
.RData
.RDataTmp
.Ruserdata

# Session / project files
.Rproj.user/
*.Rproj

# Compiled
*.o
*.so
*.dll
*.rds

# R package check / build
..Rcheck/
*.Rcheck/
vignettes/*.html
vignettes/*.pdf
*_cache/
/cache/

# renv (R dependency management)
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/staging/

# knitr / R Markdown
*.utf8.md
*.knit.md

# ──────────────────────────────────────────────────────────────
# Claude Code
# ──────────────────────────────────────────────────────────────
# Local, machine-specific settings and state stay out of the repo.
# NOTE: CLAUDE.md and .claude/settings.json are committed on purpose
# (shared project config), so they are force-unignored below.
.claude/*
!.claude/settings.json
.claude/settings.local.json
CLAUDE.local.md

# ──────────────────────────────────────────────────────────────
# Misc build / coverage / temp
# ──────────────────────────────────────────────────────────────
coverage/
*.cov
*.log
*.tmp
